# SwarmKit Configuration
# Copy this file to .env and fill in your values

# OpenAI API key (optional — needed only for LLM-backed agents)
OPENAI_API_KEY=sk-your-key-here

# Logging level: DEBUG, INFO, WARNING, ERROR
SWARMKIT_LOG_LEVEL=INFO

# Maximum concurrent agents in a swarm
SWARMKIT_MAX_AGENTS=50

# Default timeout for agent tasks (seconds)
SWARMKIT_TASK_TIMEOUT=30

# Consensus threshold (0.0 - 1.0) — fraction of agents that must agree
SWARMKIT_CONSENSUS_THRESHOLD=0.5
